{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/message-event/2.1.0/message-event.json",
  "title": "MessageEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "role", "created_at", "content"],
  "properties": {
    "type": {
      "const": "message",
      "description": "Event discriminator."
    },
    "role": {
      "type": "string",
      "enum": ["user", "assistant", "system"],
      "description": "Who authored the message."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp."
    },
    "content": {
      "$ref": "#/$defs/MessageContent"
    },
    "_meta": {
      "$ref": "#/$defs/Meta",
      "description": "Instrumentation and operational metadata (not user-facing content)."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "content": {
            "properties": {
              "items": {
                "contains": {
                  "type": "object",
                  "properties": { "type": { "const": "tool_result" } },
                  "required": ["type"]
                }
              }
            },
            "required": ["items"]
          }
        },
        "required": ["content"]
      },
      "then": {
        "properties": {
          "content": {
            "properties": {
              "items": {
                "contains": {
                  "type": "object",
                  "properties": { "type": { "const": "tool_call" } },
                  "required": ["type"]
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "MessageContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "description": "Ordered message items. Array order is the render order.",
          "items": { "$ref": "#/$defs/Item" }
        }
      }
    },

    "Item": {
      "description": "A single renderable or non-renderable item within a message.",
      "oneOf": [
        { "$ref": "#/$defs/TextItem" },
        { "$ref": "#/$defs/ImageItem" },
        { "$ref": "#/$defs/AudioItem" },
        { "$ref": "#/$defs/VideoItem" },
        { "$ref": "#/$defs/FileItem" },
        { "$ref": "#/$defs/ToolCallItem" },
        { "$ref": "#/$defs/ToolResultItem" }
      ]
    },

    "TextItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "renderable", "data"],
      "properties": {
        "type": { "const": "text", "description": "Text item." },
        "renderable": {
          "const": true,
          "description": "Whether this item should be rendered to end users."
        },
        "data": { "$ref": "#/$defs/TextData" }
      }
    },

    "ImageItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "renderable", "data"],
      "properties": {
        "type": { "const": "image", "description": "Specialized file item for images." },
        "renderable": { "const": true, "description": "Whether this item should be rendered to end users." },
        "data": { "$ref": "#/$defs/ImageData" }
      }
    },

    "AudioItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "renderable", "data"],
      "properties": {
        "type": { "const": "audio", "description": "Specialized file item for audio." },
        "renderable": { "const": true, "description": "Whether this item should be rendered to end users." },
        "data": { "$ref": "#/$defs/AudioData" }
      }
    },

    "VideoItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "renderable", "data"],
      "properties": {
        "type": { "const": "video", "description": "Specialized file item for video." },
        "renderable": { "const": true, "description": "Whether this item should be rendered to end users." },
        "data": { "$ref": "#/$defs/VideoData" }
      }
    },

    "FileItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "renderable", "data"],
      "properties": {
        "type": { "const": "file", "description": "Generic file item." },
        "renderable": { "const": true, "description": "Whether this item should be rendered to end users." },
        "data": { "$ref": "#/$defs/FileData" }
      }
    },

    "ToolCallItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "renderable", "data"],
      "properties": {
        "type": { "const": "tool_call", "description": "Non-renderable tool invocation." },
        "renderable": {
          "const": false,
          "description": "Whether this item should be rendered to end users."
        },
        "data": { "$ref": "#/$defs/ToolCallData" }
      }
    },

    "ToolResultItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "renderable", "data"],
      "properties": {
        "type": { "const": "tool_result", "description": "Non-renderable tool execution result." },
        "renderable": {
          "const": false,
          "description": "Whether this item should be rendered to end users."
        },
        "data": { "$ref": "#/$defs/ToolResultData" }
      }
    },

    "TextData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100000,
          "description": "Plain text content."
        }
      }
    },

    "FileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "media_type", "uri"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["uri", "base64"],
          "description": "How the file bytes are provided."
        },
        "media_type": {
          "type": "string",
          "minLength": 3,
          "description": "IANA media type (MIME type)."
        },
        "uri": {
          "type": "string",
          "description": "If source=uri, an absolute URI. If source=base64, the base64 payload without a data: prefix."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "source": { "const": "uri" } },
            "required": ["source"]
          },
          "then": {
            "properties": {
              "uri": {
                "format": "uri",
                "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:\\/\\/.+$"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "source": { "const": "base64" } },
            "required": ["source"]
          },
          "then": {
            "properties": {
              "uri": {
                "pattern": "^(?:[A-Za-z0-9+\\/]{4})*(?:[A-Za-z0-9+\\/]{2}==|[A-Za-z0-9+\\/]{3}=)?$",
                "contentEncoding": "base64"
              }
            }
          }
        }
      ]
    },

    "FileData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "filename"],
      "properties": {
        "ref": { "$ref": "#/$defs/FileRef" },
        "filename": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "Original file name (for display/download)."
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes (if known)."
        }
      }
    },

    "ImageData": {
      "allOf": [
        { "$ref": "#/$defs/FileData" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ref": {
              "properties": {
                "media_type": { "pattern": "^image\\/(png|jpeg|webp)$" }
              },
              "required": ["media_type"]
            },
            "width": {
              "type": "integer",
              "minimum": 1,
              "description": "Pixel width (if known)."
            },
            "height": {
              "type": "integer",
              "minimum": 1,
              "description": "Pixel height (if known)."
            }
          }
        }
      ],
      "description": "Image-specific file payload."
    },

    "AudioData": {
      "allOf": [
        { "$ref": "#/$defs/FileData" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ref": {
              "properties": {
                "media_type": { "pattern": "^audio\\/(mpeg|mp4|wav|webm|ogg)$" }
              },
              "required": ["media_type"]
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 1,
              "description": "Audio duration in milliseconds (if known)."
            }
          }
        }
      ],
      "description": "Audio-specific file payload."
    },

    "VideoData": {
      "allOf": [
        { "$ref": "#/$defs/FileData" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ref": {
              "properties": {
                "media_type": { "pattern": "^video\\/(mp4|webm|ogg)$" }
              },
              "required": ["media_type"]
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 1,
              "description": "Video duration in milliseconds (if known)."
            }
          }
        }
      ],
      "description": "Video-specific file payload."
    },

    "ToolCallData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["call_id", "name", "args"],
      "properties": {
        "call_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable identifier to correlate a tool call with its result."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Tool name."
        },
        "args": {
          "type": "object",
          "description": "Structured tool arguments. Tool-specific validation is handled at the application layer."
        }
      }
    },

    "ToolResultData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["call_id", "status"],
      "properties": {
        "call_id": {
          "type": "string",
          "minLength": 1,
          "description": "Must reference a tool_call.call_id (enforced partially via co-occurrence rules)."
        },
        "status": {
          "type": "string",
          "enum": ["ok", "error"],
          "description": "Execution outcome."
        },
        "result": {
          "description": "Tool output payload (present when status=ok).",
          "type": ["object", "array", "string", "number", "boolean", "null"]
        },
        "error": {
          "description": "Serialized error payload (present when status=error).",
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "ok" } }, "required": ["status"] },
          "then": { "required": ["result"] }
        },
        {
          "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
          "then": { "required": ["error"] }
        }
      ]
    },

    "Meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "client_msg_id": {
          "type": "string",
          "description": "Client-generated UUID for idempotency."
        },
        "request_id": {
          "type": "string",
          "description": "Backend request identifier."
        },
        "trace_id": {
          "type": "string",
          "description": "Distributed tracing identifier."
        },
        "model": {
          "type": "string",
          "description": "Model identifier used to generate assistant content."
        },
        "timing_ms": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total": { "type": "number", "minimum": 0, "description": "End-to-end duration." },
            "llm": { "type": "number", "minimum": 0, "description": "Model execution duration." },
            "db": { "type": "number", "minimum": 0, "description": "Database time." },
            "cache": { "type": "number", "minimum": 0, "description": "Cache time." },
            "upload": { "type": "number", "minimum": 0, "description": "Upload time for external media (if any)." }
          }
        },
        "tokens": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "input": { "type": "integer", "minimum": 0, "description": "Input token count." },
            "output": { "type": "integer", "minimum": 0, "description": "Output token count." }
          }
        }
      }
    }
  }
}
